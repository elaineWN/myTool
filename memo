<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MemoFlow - 极简知识库</title>
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 Vue 3 -->
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <style>
        /* 全局极简字体与背景 */
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #FAFAFA; color: #1A1A1A; }
        
        /* 3D 翻转卡片核心 CSS */
        .card-container { perspective: 1000px; }
        .card-inner { 
            position: relative; width: 100%; height: 100%; 
            transition: transform 0.6s cubic-bezier(0.4, 0.0, 0.2, 1); 
            transform-style: preserve-3d; 
        }
        .card-inner.is-flipped { transform: rotateY(180deg); }
        .card-face { 
            position: absolute; width: 100%; height: 100%; 
            backface-visibility: hidden; 
            display: flex; align-items: center; justify-content: center;
            padding: 2rem; box-sizing: border-box;
        }
        .card-front { background-color: #FFFFFF; border: 1px solid #E5E5E5; border-radius: 16px; }
        .card-back { background-color: #1A1A1A; color: #FFFFFF; border-radius: 16px; transform: rotateY(180deg); }
        
        /* 隐藏滚动条但保留功能 */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="h-screen flex justify-center">

    <div id="app" class="w-full max-w-md h-full bg-white flex flex-col relative shadow-2xl sm:shadow-none">
        
        <!-- ================= 顶部内容区域 (根据页面切换) ================= -->
        <main class="flex-1 overflow-y-auto pb-20">
            
            <!-- 1. 首页 (Home) -->
            <div v-if="currentPage === 'home'" class="p-6">
                <h1 class="text-2xl font-bold mb-1">早上好 👋</h1>
                <p class="text-gray-500 text-sm mb-6">今天也要坚持复习哦</p>

                <!-- 今日统计 -->
                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-3xl font-bold">12</p>
                        <p class="text-xs text-gray-500 mt-1">待复习</p>
                    </div>
                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-3xl font-bold">5</p>
                        <p class="text-xs text-gray-500 mt-1">新卡片</p>
                    </div>
                </div>

                <!-- 7天复习预测条 (横向滑动) -->
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">未来 7 天预测</h2>
                <div class="flex space-x-3 overflow-x-auto no-scrollbar pb-4">
                    <div v-for="(day, index) in forecast" :key="index" 
                         class="flex-shrink-0 w-14 h-20 flex flex-col items-center justify-center rounded-xl border transition-all"
                         :class="index === 0 ? 'bg-black text-white border-black' : 'bg-white text-gray-600 border-gray-200'">
                        <span class="text-xs mb-1">{{ day.weekday }}</span>
                        <span class="text-lg font-bold">{{ day.count }}</span>
                    </div>
                </div>

                <!-- 开始复习大按钮 -->
                <button @click="startStudy" class="w-full mt-8 bg-black text-white py-4 rounded-2xl font-bold text-lg shadow-lg active:scale-95 transition-transform">
                    开始今日复习
                </button>
            </div>

            <!-- 2. 目录页 (Decks) -->
            <div v-if="currentPage === 'decks'" class="p-6">
                <h1 class="text-2xl font-bold mb-6">我的知识库</h1>
                
                <!-- Deck 列表 -->
                <div class="space-y-3">
                    <div v-for="deck in decks" :key="deck.id" @click="openDeck(deck)" 
                         class="p-4 bg-white border border-gray-200 rounded-xl flex justify-between items-center active:bg-gray-50 transition-colors">
                        <div>
                            <h3 class="font-bold text-lg">{{ deck.name }}</h3>
                            <p class="text-xs text-gray-500 mt-1">共 {{ deck.cards.length }} 张卡片</p>
                        </div>
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </div>
                </div>
            </div>

            <!-- 2.1 目录详情页 (Deck Detail - 展示卡片智能名称) -->
            <div v-if="currentPage === 'deckDetail'" class="p-6">
                <button @click="currentPage = 'decks'" class="text-sm text-gray-500 mb-4 flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg> 返回
                </button>
                <h1 class="text-2xl font-bold mb-6">{{ currentDeck.name }}</h1>
                
                <div class="space-y-3">
                    <div v-for="card in currentDeck.cards" :key="card.id" class="p-4 bg-gray-50 rounded-xl border border-gray-100">
                        <!-- 智能提取的卡片名称 -->
                        <h4 class="font-bold text-gray-800">{{ extractTitle(card.front) }}</h4>
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-xs px-2 py-1 bg-white border border-gray-200 rounded-full text-gray-500">
                                {{ card.interval === 0 ? '新卡' : card.interval + '天后复习' }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. 学习页 (Study Session) -->
            <div v-if="currentPage === 'study'" class="h-full flex flex-col p-6 bg-gray-50">
                <!-- 顶部操作栏 -->
                <div class="flex justify-between items-center mb-6">
                    <button @click="currentPage = 'home'" class="text-gray-500">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                    <div class="flex-1 mx-4 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                        <div class="h-full bg-black transition-all duration-300" :style="{ width: studyProgress + '%' }"></div>
                    </div>
                    <span class="text-sm font-mono text-gray-500">{{ currentCardIndex + 1 }}/{{ totalStudyCards }}</span>
                </div>

                <!-- 3D 翻转卡片区域 -->
                <div class="flex-1 flex items-center justify-center card-container">
                    <div class="w-full h-80 card-inner" :class="{ 'is-flipped': isFlipped }" @click="isFlipped = !isFlipped">
                        <!-- 正面 -->
                        <div class="card-face card-front shadow-sm">
                            <div class="text-center text-lg leading-relaxed whitespace-pre-wrap">{{ currentCard.front }}</div>
                        </div>
                        <!-- 背面 -->
                        <div class="card-face card-back shadow-lg">
                            <div class="text-center text-lg leading-relaxed whitespace-pre-wrap">{{ currentCard.back }}</div>
                        </div>
                    </div>
                </div>
                <p class="text-center text-xs text-gray-400 mt-4">点击卡片翻转</p>

                <!-- 底部评估按钮 (翻转后显示) -->
                <div v-if="isFlipped" class="grid grid-cols-4 gap-2 mt-6 animate-fade-in">
                    <button @click="rateCard(1)" class="py-3 bg-white border border-red-100 text-red-500 rounded-xl text-sm font-bold active:bg-red-50">忘记</button>
                    <button @click="rateCard(2)" class="py-3 bg-white border border-orange-100 text-orange-500 rounded-xl text-sm font-bold active:bg-orange-50">困难</button>
                    <button @click="rateCard(3)" class="py-3 bg-white border border-green-100 text-green-600 rounded-xl text-sm font-bold active:bg-green-50">良好</button>
                    <button @click="rateCard(4)" class="py-3 bg-black text-white rounded-xl text-sm font-bold active:bg-gray-800">简单</button>
                </div>
            </div>

            <!-- 4. 我的 (Profile) -->
            <div v-if="currentPage === 'profile'" class="p-6">
                <h1 class="text-2xl font-bold mb-6">我的</h1>
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-100 flex items-center">
                    <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center text-white font-bold">U</div>
                    <div class="ml-4">
                        <p class="font-bold">本地体验用户</p>
                        <p class="text-xs text-gray-500">点击接入 Supabase 登录</p>
                    </div>
                </div>
            </div>
        </main>

        <!-- ================= 底部导航栏 (学习页隐藏) ================= -->
        <nav v-if="currentPage !== 'study'" class="absolute bottom-0 w-full bg-white border-t border-gray-100 px-6 py-3 flex justify-around">
            <button @click="currentPage = 'home'" :class="currentPage === 'home' ? 'text-black' : 'text-gray-400'" class="flex flex-col items-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="text-xs mt-1">首页</span>
            </button>
            <button @click="currentPage = 'decks'" :class="currentPage === 'decks' || currentPage === 'deckDetail' ? 'text-black' : 'text-gray-400'" class="flex flex-col items-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <span class="text-xs mt-1">目录</span>
            </button>
            <button @click="currentPage = 'profile'" :class="currentPage === 'profile' ? 'text-black' : 'text-gray-400'" class="flex flex-col items-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="text-xs mt-1">我的</span>
            </button>
        </nav>
    </div>

    <script>
        const { createApp, ref, computed } = Vue;

        createApp({
            setup() {
                const currentPage = ref('home');
                const isFlipped = ref(false);
                const currentCardIndex = ref(0);
                const currentDeck = ref(null);

                // 模拟未来 7 天预测数据
                const forecast = ref([
                    { weekday: '今天', count: 12 },
                    { weekday: '明天', count: 5 },
                    { weekday: '周五', count: 20 },
                    { weekday: '周六', count: 8 },
                    { weekday: '周日', count: 15 },
                    { weekday: '周一', count: 3 },
                    { weekday: '周二', count: 25 }
                ]);

                // 模拟知识库数据 (包含 Markdown 格式)
                const decks = ref([
                    {
                        id: 1, 
                        name: '前端基础',
                        cards: [
                            { id: 101, front: '# 什么是闭包？\n\n请用一句话简述概念。', back: '闭包是指一个函数能够记住并访问它所在的词法作用域，即使这个函数在其词法作用域之外执行。', interval: 0 },
                            { id: 102, front: 'Vue3 的响应式原理是什么？', back: '基于 ES6 的 Proxy 对象实现，拦截数据的读取和修改。', interval: 1 },
                            { id: 103, front: 'CSS 中 `box-sizing: border-box` 的作用？', back: '让元素的宽度和高度包含边框和内边距，方便布局计算。', interval: 3 }
                        ]
                    },
                    {
                        id: 2, 
                        name: '英语单词',
                        cards: [
                            { id: 201, front: 'Ephemeral', back: 'adj. 短暂的，瞬息的', interval: 0 }
                        ]
                    }
                ]);

                // 当前正在学习的卡片
                const currentCard = computed(() => {
                    // 简单逻辑：把第一个 deck 的卡片拿出来复习
                    return decks.value[0].cards[currentCardIndex.value] || decks.value[0].cards[0];
                });

                const totalStudyCards = computed(() => decks.value[0].cards.length);
                const studyProgress = computed(() => ((currentCardIndex.value + 1) / totalStudyCards.value) * 100);

                // 智能提取卡片名称 (去除 Markdown 标记，取前 20 字符)
                const extractTitle = (content) => {
                    return content.replace(/[#*`>\-\[\]()]/g, '').replace(/\n/g, ' ').trim().substring(0, 20) + (content.length > 20 ? '...' : '');
                };

                const openDeck = (deck) => {
                    currentDeck.value = deck;
                    currentPage.value = 'deckDetail';
                };

                const startStudy = () => {
                    currentPage.value = 'study';
                    isFlipped.value = false;
                    currentCardIndex.value = 0;
                };

                // 评估卡片 (模拟 SM-2 算法的下一步)
                const rateCard = (rating) => {
                    console.log(`用户评分: ${rating}`);
                    isFlipped.value = false;
                    
                    // 模拟进入下一张卡片
                    setTimeout(() => {
                        if (currentCardIndex.value < totalStudyCards.value - 1) {
                            currentCardIndex.value++;
                        } else {
                            alert('太棒了！今日复习完成！');
                            currentPage.value = 'home';
                        }
                    }, 300); // 等待翻转动画复位
                };

                return {
                    currentPage, isFlipped, forecast, decks, 
                    currentCard, currentCardIndex, totalStudyCards, studyProgress, currentDeck,
                    extractTitle, openDeck, startStudy, rateCard
                };
            }
        }).mount('#app');
    </script>
</body>
</html>
